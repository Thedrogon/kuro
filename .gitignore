# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go build command
# If you build with 'go build -o myapp', add 'myapp' here
bin/

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# Dependency directories (only uncomment if you are NOT using Go modules)
# vendor/

# Environment files
.env

# Editor-specific files (consider adding these to global gitignore instead)
.idea/
.vscode/
*.swp
